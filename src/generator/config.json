        }
      }
    },
    "thick": {
      "brew": {
        "water": {
          "items": ["minecraft:glowstone_dust"]
        }
      }
    }
  },
  "modifiers": {
    "extended": {
      "reagent": {
        "items": ["minecraft:redstone"]
      },
      "variant_transform": {
        "from": "base",
        "to": "long"
      }
    },
    "strong": {
      "reagent": {
        "items": ["minecraft:glowstone_dust"]
      },
      "variant_transform": {
        "from": "base",
        "to": "strong"
      }
    },
    "corrupting": {
      "reagent": {
        "items": ["minecraft:fermented_spider_eye"]
      }
    },
    "splash": {
      "reagent": {
        "items": ["minecraft:gunpowder"]
      },
      "container_conversion": {
        "from": "regular",
        "to": "splash"
      }
    },
    "lingering": {
      "reagent": {
        "items": ["minecraft:dragon_breath"]
      },
      "container_conversion": {
        "from": "splash",
        "to": "lingering"
      }
    },
    "no_particles": {
      "reagent": {
        "items": ["minecraft:resin_clump"]
      },
      "global": {
        "apply_to": ["custom", "vanilla"],
        "input_show_particles": true,
        "output_show_particles": false,
        "components": {
          "minecraft:lore": [
            {
              "translate": "overbrew.lore.no_particles",
              "fallback": "No Particles",
              "italic": false,
              "color": "#FC7812"
            }
          ]
        }
      }
    }
  },
